                                {
                                    Debug = Arg3
                                    Debug = "Get EC thresholds for 45"
                                    TTGP [Zero] = 0x02
                                    TTGP [One] = ((EDID << 0x04) + ETID) /* \_SB_.TZ45.ETID */
                                    Local1 = Zero
                                    Local0 = \_SB.I2C6._DSM (\_SB.I2C6.DSMF, Zero, \_SB.I2C6.FF10, TTGP)
                                    While (One)
                                    {
                                        Name (_T_3, 0x00)  // _T_x: Emitted by ASL Compiler, x=0-9, A-Z
                                        _T_3 = DerefOf (Arg3 [One])
                                        If ((_T_3 == Zero))
                                        {
                                            Local1 = (((Local0 & 0xFF) + 0x0111) * 0x0A)
                                            Return (Local1)
                                        }
                                        ElseIf ((_T_3 == One))
                                        {
                                            Local1 = ((((Local0 >> 0x08) & 0xFF) + 0x0111
                                                ) * 0x0A)
                                            Return (Local1)
                                        }
                                        ElseIf ((_T_3 == 0x02))
                                        {
                                            Local1 = ((((Local0 >> 0x10) & 0xFF) + 0x0111
                                                ) * 0x0A)
                                            Return (Local1)
                                        }
                                        ElseIf ((_T_3 == 0x03))
                                        {
                                            Local1 = ((((Local0 >> 0x18) & 0xFF) + 0x0111
                                                ) * 0x0A)
                                            Return (Local1)
                                        }
                                        ElseIf ((_T_3 == 0x04))
                                        {
                                            Acquire (\_SB.TZMX, 0xFFFF)
                                            \_SB.TZ45.TPSV = (((Local0 & 0xFF) + 0x0111) * 0x0A)
                                            Release (\_SB.TZMX)
                                            \_SB.TZ45.TCR3 = ((((Local0 >> 0x08) & 0xFF) + 0x0111
                                                ) * 0x0A)
                                            \_SB.TZ45.THOT = ((((Local0 >> 0x10) & 0xFF) + 0x0111
                                                ) * 0x0A)
                                            \_SB.TZ45.TCRT = ((((Local0 >> 0x18) & 0xFF) + 0x0111
                                                ) * 0x0A)
                                            Return (Local1)
                                        }
                                        Else
                                        {
                                            Return (Zero)
                                        }

                                        Break
                                    }
                                }
                                ElseIf ((DerefOf (Arg3 [Zero]) == One))
                                {
                                    Debug = Arg3
                                    Debug = "Set EC thresholds for 45"
                                    TTGP [Zero] = One
                                    TTGP [One] = ((EDID << 0x04) + ETID) /* \_SB_.TZ45.ETID */
                                    Local1 = DerefOf (Arg3 [0x02])
                                    While (One)
                                    {
                                        Name (_T_4, 0x00)  // _T_x: Emitted by ASL Compiler, x=0-9, A-Z
                                        _T_4 = DerefOf (Arg3 [One])
                                        If ((_T_4 == Zero))
                                        {
                                            TTGP [0x02] = ((((((\_SB.TZ45.TCRT / 0x0A
                                                ) - 0x0111) << 0x18) + (((\_SB.TZ45.THOT / 0x0A) - 0x0111) << 
                                                0x10)) + (((\_SB.TZ45.TCR3 / 0x0A) - 0x0111) << 0x08)
                                                ) + ((Local1 / 0x0A) - 0x0111))
                                            Local0 = \_SB.I2C6._DSM (\_SB.I2C6.DSMF, Zero, \_SB.I2C6.FF10, TTGP)
                                            If ((Local0 == Zero))
                                            {
                                                Acquire (\_SB.TZMX, 0xFFFF)
                                                \_SB.TZ45.TPSV = Local1
                                                Release (\_SB.TZMX)
                                                Notify (\_SB.TZ45, 0x81) // Thermal Trip Point Change
                                                Return (Local1)
                                            }
                                        }
                                        ElseIf ((_T_4 == One))
                                        {
                                            TTGP [0x02] = ((((((\_SB.TZ45.TCRT / 0x0A
                                                ) - 0x0111) << 0x18) + (((\_SB.TZ45.THOT / 0x0A) - 0x0111) << 
                                                0x10)) + (((Local1 / 0x0A) - 0x0111) << 0x08)
                                                ) + ((\_SB.TZ45.TPSV / 0x0A) - 0x0111))
                                            Local0 = \_SB.I2C6._DSM (\_SB.I2C6.DSMF, Zero, \_SB.I2C6.FF10, TTGP)
                                            If ((Local0 == Zero))
                                            {
                                                \_SB.TZ39.TCR3 = Local1
                                                Notify (\_SB.TZ45, 0x81) // Thermal Trip Point Change
                                                Return (Local1)
                                            }
                                        }
                                        ElseIf ((_T_4 == 0x02))
                                        {
                                            TTGP [0x02] = ((((((\_SB.TZ45.TCRT / 0x0A
                                                ) - 0x0111) << 0x18) + (((Local1 / 0x0A) - 0x0111) << 
                                                0x10)) + (((\_SB.TZ45.TCR3 / 0x0A) - 0x0111) << 0x08)
                                                ) + ((\_SB.TZ45.TPSV / 0x0A) - 0x0111))
                                            Local0 = \_SB.I2C6._DSM (\_SB.I2C6.DSMF, Zero, \_SB.I2C6.FF10, TTGP)
                                            If ((Local0 == Zero))
                                            {
                                                \_SB.TZ45.THOT = Local1
                                                Notify (\_SB.TZ45, 0x81) // Thermal Trip Point Change
                                                Return (Local1)
                                            }
                                        }
                                        ElseIf ((_T_4 == 0x03))
                                        {
                                            TTGP [0x02] = ((((((Local1 / 0x0A
                                                ) - 0x0111) << 0x18) + (((\_SB.TZ45.THOT / 0x0A) - 0x0111) << 
                                                0x10)) + (((\_SB.TZ45.TCR3 / 0x0A) - 0x0111) << 0x08)
                                                ) + ((\_SB.TZ45.TPSV / 0x0A) - 0x0111))
                                            Local0 = \_SB.I2C6._DSM (\_SB.I2C6.DSMF, Zero, \_SB.I2C6.FF10, TTGP)
                                            If ((Local0 == Zero))
                                            {
                                                \_SB.TZ45.TCRT = Local1
                                                Notify (\_SB.TZ45, 0x81) // Thermal Trip Point Change
                                                Return (Local1)
                                            }
                                        }
                                        ElseIf ((_T_4 == 0x04))
                                        {
                                            TTGP [0x02] = ((((((\_SB.TZ45.TCRT / 0x0A
                                                ) - 0x0111) << 0x18) + (((\_SB.TZ45.THOT / 0x0A) - 0x0111) << 
                                                0x10)) + (((\_SB.TZ45.TCR3 / 0x0A) - 0x0111) << 0x08)
                                                ) + ((\_SB.TZ45.TPSV / 0x0A) - 0x0111))
                                            Local0 = \_SB.I2C6._DSM (\_SB.I2C6.DSMF, Zero, \_SB.I2C6.FF10, TTGP)
                                            Return (Local1)
                                        }
                                        Else
                                        {
                                            Return (Zero)
                                        }

                                        Break
                                    }
                                }
                            }
                            Else
                            {
                                Return (Buffer (One)
                                {
                                     0x00                                             // .
                                })
                            }

                            Break
                        }
                    }

                    Break
                }
            }

            Method (_TMP, 0, NotSerialized)  // _TMP: Temperature
            {
                While ((CNTR < CNTM))
                {
                    Debug = "TZ 45 while loop"
                    Debug = CNTR /* \_SB_.TZ45.CNTR */
                    Debug = CNTM /* \_SB_.TZ45.CNTM */
                    CNTR++
                    TEMP = \_SB.I2C6._DSM (\_SB.I2C6.DSME, Zero, \_SB.I2C6.EF06, ETID)
                    If ((TEMP != 0xFF))
                    {
                        Break
                    }

                    TEMP = Zero
                    Sleep (0x32)
                }

                CNTR = Zero
                If (((TEMP & 0x8000) == 0x8000))
                {
                    TEMP = (TEMP ^ 0xFFFF)
                    TEMP = (TEMP + One)
                    TEMP = (TEMP * 0x0A)
                    TEMP = (0x0AAA - TEMP)
                }
                Else
                {
                    TEMP = ((TEMP + 0x0111) * 0x0A)
                }

                Debug = "Tz 45 _TMP"
                Debug = TEMP /* \_SB_.TZ45.TEMP */
                If ((THGF == One))
                {
                    Debug = "Get Thresholds from TZ 45"
                    THGP [Zero] = 0x02
                    THGP [One] = 0x04
                    Local0 = \_SB.TZ45._DSM (\_SB.TZ45.DSME, Zero, 0x02, THGP)
                    THGF = Zero
                }

                Return (TEMP) /* \_SB_.TZ45.TEMP */
            }

            Method (_STA, 0, NotSerialized)  // _STA: Status
            {
                If ((\_SB.SDFE == 0x88))
                {
                    Return (Zero)
                }
                ElseIf ((\_SB.SDFE == 0x9A))
                {
                    Return (Zero)
                }
            }

            Method (_DEP, 0, NotSerialized)  // _DEP: Dependencies
            {
                Return (Package (0x01)
                {
                    \_SB.I2C6
                })
            }
        }

        Name (HWNH, Zero)
        Device (HWN1)
        {
            Name (_HID, "QCOM0C69")  // _HID: Hardware ID
            Name (_UID, One)  // _UID: Unique ID
            Alias (\_SB.PSUB, _SUB)
