                {
                    CHRV = (CHRV | (One << Zero))
                    CHRV = (CHRV | (One << One))
                    CHRV = (CHRV | (One << 0x04))
                }

                If ((DPBM & (One << 0x02)))
                {
                    CHRV = (CHRV | (One << One))
                }

                If ((DPBM & (One << 0x07)))
                {
                    CHRV = (CHRV | (One << 0x02))
                }

                If ((DPBM & (One << 0x0F)))
                {
