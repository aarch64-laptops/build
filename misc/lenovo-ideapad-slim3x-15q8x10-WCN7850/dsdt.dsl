                                        Debug = CNTM /* \_SB_.PEP0._DSM.CNTM */
                                        CNTR++
                                        TVAL = \_SB.I2C6._DSM (\_SB.I2C6.DSMF, Zero, \_SB.I2C6.FF02, Zero)
